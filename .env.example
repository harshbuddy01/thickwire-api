# Database
DATABASE_URL=postgresql://user:password@localhost:5432/thickwire?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-64-char-random-hex-string-here
JWT_REFRESH_SECRET=your-different-64-char-random-hex-string-here

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-aes-256-key-here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@yourdomain.com

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# CORS
FRONTEND_URL=https://yourdomain.com
ADMIN_URL=https://admin.yourdomain.com

# App
NODE_ENV=development
PORT=3001
TOTP_ISSUER=ThickWire
